#!/usr/bin/env bash
# mcpshell launcher — builds the CLI on demand for the host OS/arch and runs it.
#
#   ./bin/mcpshell '<code>'     evaluate code
#   BUILD=true ./bin/mcpshell   force a rebuild before running
#
# A per-arch binary is cached at bin/mcpshell-<os>-<arch>, so the same launcher
# works across machines and architectures. The binary is rebuilt automatically
# when it is missing, when any Go source is newer than it, or when BUILD=true.
set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if ! command -v go >/dev/null 2>&1; then
  echo "mcpshell: Go toolchain not found on PATH" >&2
  exit 1
fi

goos="$(go env GOOS)"
goarch="$(go env GOARCH)"
bin="$root/bin/mcpshell-${goos}-${goarch}"

needs_build=false
if [[ "${BUILD:-}" == "true" ]]; then
  needs_build=true
elif [[ ! -x "$bin" ]]; then
  needs_build=true
elif [[ -n "$(find "$root" -name '*.go' -not -path '*/bin/*' -newer "$bin" -print -quit 2>/dev/null)" ]]; then
  needs_build=true
fi

if [[ "$needs_build" == "true" ]]; then
  echo "mcpshell: building ${goos}/${goarch}..." >&2
  ( cd "$root" && go build -o "$bin" ./cmd/mcpshell )
fi

exec "$bin" "$@"
