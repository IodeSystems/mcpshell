# mcpshell local config. Copy this file to env.local (which is gitignored)
# and edit. `mcpshell bench` reads these; real environment variables override
# anything set here.

# Base URL of an OpenAI-compatible LLM API.
MCPSHELL_LLM_URL=https://llm.iodesystems.com

# Model to benchmark. An exact model id, or a substring matched
# case-insensitively against the server's /v1/models list.
MCPSHELL_LLM_MODEL=mpt

# API key, if the server requires one. Leave unset for an open endpoint.
# MCPSHELL_LLM_API_KEY=
